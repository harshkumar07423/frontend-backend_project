# .env — BhumiSetu Configuration
# Copy this to .env and update with your MongoDB URI

# Local MongoDB (default)
MONGO_URI=mongodb://127.0.0.1:27017/bhumisetu

# MongoDB Atlas (Cloud) — replace with your connection string
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/bhumisetu?retryWrites=true&w=majority

PORT=3000
